# Enterprise CPQ — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Public domain (used by Caddy in production)
DOMAIN=localhost

# ── MongoDB ───────────────────────────────────────────────────────────────────
# The backend constructs the URI from these components — no interpolation needed.
# MONGO_HOST: use "localhost" here for outside-Docker dev; Docker Compose overrides
# it to "mongodb" (the service name) via the api service environment block.
MONGO_HOST=localhost
MONGO_USER=your_mongo_username
MONGO_PASS=your_mongo_password
MONGO_DATABASE=enterprise-cpq

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_minimum_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret_min_32_chars

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of the React SPA (used in email links and OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Allowed CORS origin for the Express API in development
CORS_ORIGIN=http://localhost:5173

# ── Salesforce OAuth (FR-AUTH-3) ──────────────────────────────────────────────
# Leave blank to disable Salesforce login. All four values must be set to enable.
SF_CONSUMER_KEY=
SF_CONSUMER_SECRET=
SF_INSTANCE_URL=https://login.salesforce.com
SF_CALLBACK_URL=http://localhost:3001/api/auth/salesforce/callback

# ── SMTP / Email ──────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com
